{
  "title": "Sample Form",
  "width": 400,
  "height": 300,
  "controls": [
    {
      "type": "Label",
      "text": "Name:",
      "rect": [20, 20, 60, 20]
    },
    {
      "type": "TextBox",
      "rect": [90, 18, 200, 24],
      "id": 101
    },
    {
      "type": "Label",
      "text": "Email:",
      "rect": [20, 55, 60, 20]
    },
    {
      "type": "TextBox",
      "rect": [90, 53, 200, 24],
      "id": 102
    },
    {
      "type": "GroupBox",
      "text": "Options",
      "rect": [20, 90, 270, 100],
      "children": [
        {
          "type": "CheckBox",
          "text": "Subscribe to newsletter",
          "rect": [15, 25, 200, 20],
          "id": 201
        },
        {
          "type": "CheckBox",
          "text": "Accept terms and conditions",
          "rect": [15, 50, 200, 20],
          "id": 202
        }
      ]
    },
    {
      "type": "Button",
      "text": "Submit",
      "rect": [90, 210, 100, 30],
      "id": 301,
      "style": 1,
      "onClick": "submit_form"
    },
    {
      "type": "Button",
      "text": "Cancel",
      "rect": [200, 210, 100, 30],
      "id": 302,
      "onClick": "cancel_form"
    }
  ]
}
